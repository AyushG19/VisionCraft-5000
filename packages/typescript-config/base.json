{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "lib": ["es2022", "DOM", "DOM.Iterable"],
    "module": "NodeNext",
    "moduleDetection": "force",
    "moduleResolution": "NodeNext",
    "noUncheckedIndexedAccess": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "baseUrl": ".",
    "paths": {
      "@repo/common": ["packages/common/src/index.ts"],
      "@repo/db": ["packages/db/src/index.ts"],
      "@repo/redis": ["packages/redis/src/index.ts"],
      "@repo/queue": ["packages/queue/src/index.ts"],
      "@repo/hooks": ["packages/hooks/src/index.ts"],
      "@repo/backend-common": ["packages/backend-common/src/index.ts"]
    }
  }
}
